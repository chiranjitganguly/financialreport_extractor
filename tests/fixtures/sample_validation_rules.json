    "rule_type": "tally",
    "formula": "abs(KPI_NET - (KPI_REV - KPI_EXP)) <= tolerance",
    "participating_kpi_ids": ["KPI_NET", "KPI_REV", "KPI_EXP"],
    "tolerance": 0.01
  },
  {
    "rule_id": "TALLY_MISSING_OPERAND",
